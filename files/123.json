{
  "name": "snp",
  "description": "",
  "type": "GLOBAL",
  "globalProxy": false,
  "geoipUrl": "https://github.com/Sn1pp1/mygeofiles/releases/download/latest/geoip.dat",
  "geositeUrl": "https://github.com/Sn1pp1/mygeofiles/releases/download/latest/geosite.dat",
  "directDomains": [
    "geosite:PRIVATE",
    "geosite:CATEGORY-RU"
  ],
  "proxyDomains": [
    "geosite:RU-BLOCKED",
    "geosite:DISCORD",
    "geosite:DOMAIN-LIST",
    "geosite:META",
    "geosite:TELEGRAM",
    "geosite:YOUTUBE",
    "geosite:GOOGLE-DEEPMIND",
    "geosite:GOOGLE-PLAY",
    "geosite:CLOUDFLARE"
  ],
  "blockDomains": [
    "geosite:CATEGORY-ADS"
  ],
  "directIp": [
    "geoip:PRIVATE",
    "geoip:IPS-FOR-RU"
  ],
  "proxyIp": [
    "geoip:DISCORD",
    "geoip:META",
    "geoip:RU-BLOCKED",
    "geoip:RU-BLOCKED-COMMUNITY",
    "geoip:TELEGRAM",
    "geoip:CLOUDFLARE"
  ],
  "blockIp": [],
  "domainStrategy": "IPIfNonMatch",
  "routeOrder": "block-proxy-direct",
  "useChunkFiles": true,
  "bypassPrivateIps": true,
  "bypassLocalDns": false,
  "updateInterval": 43200
}
